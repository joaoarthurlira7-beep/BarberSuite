<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Barberia - Luxury Grooming</title>
    <style>
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #1a1a1a;
            --bg-card: rgba(26, 26, 26, 0.8);
            --bg-glass: rgba(255, 255, 255, 0.05);
            --text-primary: #ffffff;
            --text-secondary: #b8b8b8;
            --accent-gold: #d4af37;
            --accent-gold-dark: #b8942f;
            --accent-silver: #c0c0c0;
            --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.5);
            --shadow-hover: 0 20px 50px rgba(212, 175, 55, 0.3);
            --glow-gold: 0 0 20px rgba(212, 175, 55, 0.6);
            --border-glass: 1px solid rgba(255, 255, 255, 0.1);
            --transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            overflow-x: hidden;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 10, 10, 0.95);
            backdrop-filter: blur(20px);
            border-bottom: var(--border-glass);
            z-index: 1000;
            padding: 1rem 0;
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 2rem;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 2rem;
        }

        .nav-link {
            color: var(--text-primary);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 25px;
            font-weight: 500;
            transition: var(--transition);
            position: relative;
        }

        .nav-link:hover, .nav-link.active {
            background: var(--bg-glass);
            box-shadow: var(--glow-gold);
            transform: translateY(-2px);
        }

        main {
            padding-top: 80px;
            min-height: 100vh;
        }

        section {
            min-height: 100vh;
            padding: 6rem 2rem;
            display: none;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInUp 0.8s forwards;
        }

        section.active {
            display: block;
            opacity: 1;
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Hero */
        #hero {
            background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 50%, #2a2a2a 100%),
                        radial-gradient(circle at 30% 70%, rgba(212, 175, 55, 0.2) 0%, transparent 50%),
                        radial-gradient(circle at 70% 20%, rgba(192, 192, 192, 0.1) 0%, transparent 50%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        #hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><radialGradient id="g" cx="50%" cy="50%"><stop offset="0%" stop-color="%23d4af37" stop-opacity="0.1"/><stop offset="100%" stop-color="%23d4af37" stop-opacity="0"/></radialGradient></defs><circle cx="20" cy="20" r="2" fill="url(%23g)"><animate attributeName="cy" values="20;80;20" dur="3s" repeatCount="indefinite"/></circle><circle cx="80" cy="80" r="2" fill="url(%23g)"><animate attributeName="cy" values="80;20;80" dur="4s" repeatCount="indefinite"/></circle></svg>') no-repeat center/cover;
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-20px); }
        }

        .hero-title {
            font-size: clamp(3rem, 8vw, 6rem);
            font-weight: 900;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--accent-gold), #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(212, 175, 55, 0.5);
            animation: glow 3s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { filter: drop-shadow(0 0 20px var(--accent-gold)); }
            to { filter: drop-shadow(0 0 30px var(--accent-gold)); }
        }

        .hero-subtitle {
            font-size: 1.5rem;
            margin-bottom: 3rem;
            color: var(--text-secondary);
        }

        .btn {
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-gold-dark));
            color: #000;
            border: none;
            padding: 1.2rem 3rem;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 50px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: var(--shadow-soft);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 1rem;
        }

        .btn:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: var(--glow-gold), var(--shadow-hover);
        }

        .btn-secondary {
            background: transparent;
            color: var(--accent-gold);
            border: 2px solid var(--accent-gold);
        }

        .btn-secondary:hover {
            background: var(--accent-gold);
            color: #000;
        }

        /* Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        @media (max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
        }

        /* Cards */
        .card {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 2.5rem;
            border: var(--border-glass);
            box-shadow: var(--shadow-soft);
            transition: var(--transition);
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-silver));
            transform: scaleX(0);
            transition: transform 0.3s;
        }

        .card:hover {
            transform: translateY(-15px) scale(1.02);
            box-shadow: var(--glow-gold), var(--shadow-hover);
            background: rgba(255,255,255,0.08);
        }

        .card:hover::before {
            transform: scaleX(1);
        }

        .card-icon {
            font-size: 4rem;
            display: block;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card h3 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .card p {
            color: var(--text-secondary);
            margin-bottom: 1.5rem;
        }

        /* Barber photo */
        .barber-photo {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            margin: 0 auto 1rem;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            box-shadow: var(--glow-gold);
        }

        .rating {
            color: var(--accent-gold);
            font-size: 1.2rem;
        }

        /* Booking */
        .booking-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .progress {
            display: flex;
            gap: 1rem;
            margin-bottom: 3rem;
            justify-content: center;
        }

        .progress-step {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--bg-glass);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid var(--accent-gold);
            transition: var(--transition);
        }

        .progress-step.active {
            background: var(--accent-gold);
            color: #000;
            box-shadow: var(--glow-gold);
        }

        .booking-step {
            display: none;
        }

        .booking-step.active {
            display: block;
        }

        .date-grid, .time-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 1rem;
            margin-top: 2rem;
        }

        .date-btn, .time-btn {
            padding: 1rem;
            border: var(--border-glass);
            background: var(--bg-glass);
            border-radius: 20px;
            cursor: pointer;
            transition: var(--transition);
        }

        .date-btn.available, .time-btn.available {
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-gold-dark));
            color: #000;
            box-shadow: var(--glow-gold);
        }

        /* Catalog */
        .filters {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 3rem;
        }

        .filter-btn {
            @extend .btn;
            background: var(--bg-glass);
            color: var(--text-primary);
            border: var(--border-glass);
            font-size: 1rem;
            padding: 0.8rem 1.5rem;
        }

        .filter-btn.active {
            background: var(--accent-gold);
            color: #000;
        }

        .catalog-grid {
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .look-card {
            height: 400px;
            background-size: cover;
            background-position: center;
            border-radius: 30px;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            transition: var(--transition);
        }

        .look-card::after {
            content: 'View Details';
            position: absolute;
            bottom: 2rem;
            left: 2rem;
            color: var(--accent-gold);
            font-weight: bold;
            opacity: 0;
            transition: var(--transition);
        }

        .look-card:hover {
            transform: scale(1.05);
            box-shadow: var(--glow-gold);
        }

        .look-card:hover::after {
            opacity: 1;
        }

        /* AI Chat */
        .ai-panel {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 400px;
            height: 500px;
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            border: var(--border-glass);
            box-shadow: var(--shadow-soft);
            display: none;
            flex-direction: column;
            z-index: 2000;
        }

        .ai-header {
            padding: 1.5rem;
            border-bottom: var(--border-glass);
            font-weight: bold;
            color: var(--accent-gold);
        }

        .ai-messages {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        .message {
            margin-bottom: 1rem;
            padding: 1rem;
            border-radius: 20px;
            max-width: 80%;
        }

        .message.user {
            background: var(--accent-gold);
            color: #000;
            margin-left: auto;
        }

        .message.bot {
            background: var(--bg-glass);
        }

        .ai-input {
            display: flex;
            padding: 1.5rem;
            border-top: var(--border-glass);
            gap: 1rem;
        }

        .ai-input input {
            flex: 1;
            background: var(--bg-glass);
            border: var(--border-glass);
            border-radius: 25px;
            padding: 1rem;
            color: var(--text-primary);
        }

        .ai-toggle {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--accent-gold);
            border: none;
            color: #000;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: var(--glow-gold);
            z-index: 1500;
            transition: var(--transition);
        }

        /* Customer & Admin */
        .stats-grid {
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .stat-card {
            text-align: center;
            padding: 2rem;
        }

        .stat-number {
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .list {
            max-height: 400px;
            overflow-y: auto;
        }

        .list-item {
            display: flex;
            justify-content: space-between;
            padding: 1rem;
            border-bottom: var(--border-glass);
            transition: var(--transition);
        }

        .list-item:hover {
            background: var(--bg-glass);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .nav-menu {
                gap: 1rem;
            }

            section {
                padding: 4rem 1rem;
            }

            .hero-title {
                font-size: 3rem;
            }

            .ai-panel {
                width: 90vw;
                right: 5%;
                height: 60vh;
            }

            .nav-container {
                padding: 0 1rem;
            }

            .nav-menu {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        /* Hide scrollbars */
        .ai-messages::-webkit-scrollbar,
        .list::-webkit-scrollbar {
            width: 6px;
        }

        .ai-messages::-webkit-scrollbar-track,
        .list::-webkit-scrollbar-track {
            background: var(--bg-secondary);
        }

        .ai-messages::-webkit-scrollbar-thumb,
        .list::-webkit-scrollbar-thumb {
            background: var(--accent-gold);
            border-radius: 3px;
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-container">
            <div class="logo">Elite Barberia</div>
            <ul class="nav-menu">
                <li><a href="#" class="nav-link active" data-section="hero">Home</a></li>
                <li><a href="#" class="nav-link" data-section="services">Services</a></li>
                <li><a href="#" class="nav-link" data-section="barbers">Barbers</a></li>
                <li><a href="#" class="nav-link" data-section="booking">Booking</a></li>
                <li><a href="#" class="nav-link" data-section="catalog">Catalog</a></li>
                <li><a href="#" class="nav-link" data-section="ai">AI Assistant</a></li>
                <li><a href="#" class="nav-link" data-section="customer">Customer</a></li>
                <li><a href="#" class="nav-link" data-section="admin">Admin</a></li>
            </ul>
        </div>
    </nav>

    <main>
        <!-- Hero -->
        <section id="hero" class="active">
            <h1 class="hero-title">Luxury Redefined</h1>
            <p class="hero-subtitle">Experience unparalleled grooming excellence</p>
            <div>
                <button class="btn" onclick="showSection('booking')">Book Now</button>
                <button class="btn btn-secondary" onclick="showSection('catalog')">View Cuts</button>
            </div>
        </section>

        <!-- Services -->
        <section id="services">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 3rem; background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Our Services</h2>
            <div class="grid">
                <div class="card service-card" data-service="Haircut">
                    <span class="card-icon">✂️</span>
                    <h3>Haircut</h3>
                    <p>Precision cut tailored to your style.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Haircut and Beard">
                    <span class="card-icon">🪒</span>
                    <h3>Haircut & Beard</h3>
                    <p>Complete grooming package.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Beard">
                    <span class="card-icon">✂️</span>
                    <h3>Beard Trim</h3>
                    <p>Expert beard shaping.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Highlights">
                    <span class="card-icon">🌈</span>
                    <h3>Highlights</h3>
                    <p>Subtle color enhancement.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Pigmentation">
                    <span class="card-icon">🎨</span>
                    <h3>Pigmentation</h3>
                    <p>Full color transformation.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Eyebrows">
                    <span class="card-icon">👁️</span>
                    <h3>Eyebrows</h3>
                    <p>Defined and groomed brows.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
                <div class="card service-card" data-service="Other">
                    <span class="card-icon">⭐</span>
                    <h3>Other Services</h3>
                    <p>Custom requests available.</p>
                    <button class="btn" style="width:100%;">Select</button>
                </div>
            </div>
        </section>

        <!-- Barbers -->
        <section id="barbers">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 3rem; background: linear-gradient(135deg, var(--accent-gold), var(--accent-silver)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Master Barbers</h2>
            <div class="grid">
                <div class="card barber-card" data-barber="John">
                    <div class="barber-photo">👨‍🦰</div>
                    <h3>John Doe</h3>
                    <p>Specialty: Fades</p>
                    <div class="rating">★★★★★ 4.9</div>
                    <p>Style: Modern</p>
                    <p>Available: 10AM, 2PM</p>
                    <button class="btn" style="width:100%; margin-top:1rem;">Choose</button>
                </div>
                <div class="card barber-card" data-barber="Mike">
                    <div class="barber-photo">👨</div>
                    <h3>Mike Smith</h3>
                    <p>Specialty: Classic</p>
                    <div class="rating">★★★★☆ 4.8</div>
                    <p>Style: Traditional</p>
                    <p>Available: 11AM, 3PM</p>
                    <button class="btn" style="width:100%; margin-top:1rem;">Choose</button>
                </div>
                <div class="card barber-card" data-barber="Alex">
                    <div class="barber-photo">🧔</div>
                    <h3>Alex Brown</h3>
                    <p>Specialty: Beard</p>
                    <div class="rating">★★★★★ 5.0</div>
                    <p>Style: Luxury</p>
                    <p>Available: 9AM, 4PM</p>
                    <button class="btn" style="width:100%; margin-top:1rem;">Choose</button>
                </div>
                <div class="card barber-card" data-barber="Chris">
                    <div class="barber-photo">👨‍🎨</div>
                    <h3>Chris Lee</h3>
                    <p>Specialty: Color</p>
                    <div class="rating">★★★★★ 4.9</div>
                    <p>Style: Creative</p>
                    <p>Available: 12PM, 5PM</p>
                    <button class="btn" style="width:100%; margin-top:1rem;">Choose</button>
                </div>
            </div>
        </section>

        <!-- Booking -->
        <section id="booking">
            <div class="booking-container">
                <h2 style="text-align: center; font-size: 3rem; margin-bottom: 2rem;">Smart Booking</h2>
                <div class="progress">
                    <div class="progress-step active">1</div>
                    <div class="progress-step">2</div>
                    <div class="progress-step">3</div>
                    <div class="progress-step">4</div>
                    <div class="progress-step">5</div>
                </div>
                <div id="step1" class="booking-step active">
                    <h3>Choose Service</h3>
                    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                        <button class="card service-select" data-service="Haircut">Haircut</button>
                        <button class="card service-select" data-service="Haircut and Beard">Haircut & Beard</button>
                        <!-- Add more as needed -->
                    </div>
                </div>
                <div id="step2" class="booking-step">
                    <h3>Choose Barber</h3>
                    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
                        <button class="card barber-select" data-barber="John">John Doe</button>
                        <button class="card barber-select" data-barber="Mike">Mike Smith</button>
                        <!-- etc -->
                    </div>
                </div>
                <div id="step3" class="booking-step">
                    <h3>Select Date</h3>
                    <div class="date-grid">
                        <button class="date-btn available">Today</button>
                        <button class="date-btn available">Tomorrow</button>
                        <button class="date-btn available">Fri</button>
                        <button class="date-btn">Sat</button>
                        <button class="date-btn available">Sun</button>
                    </div>
                </div>
                <div id="step4" class="booking-step">
                    <h3>Select Time</h3>
                    <div class="time-grid">
                        <button class="time-btn available">9:00 AM</button>
                        <button class="time-btn available">10:00 AM</button>
                        <button class="time-btn">11:00 AM</button>
                        <button class="time-btn available">2:00 PM</button>
                        <button class="time-btn available">4:00 PM</button>
                    </div>
                </div>
                <div id="step5" class="booking-step">
                    <h3>Confirm Booking</h3>
                    <p id="confirm-details"></p>
                    <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 2rem;">
                        <button class="btn" onclick="resetBooking()">Back</button>
                        <button class="btn" style="background: green;">Confirm</button>
                    </div>
                </div>
                <div style="text-align: center; margin-top: 2rem;">
                    <button id="next-btn" class="btn" onclick="nextStep()" style="display: none;">Next</button>
                    <button id="prev-btn" class="btn btn-secondary" onclick="prevStep()" style="display: none;">Previous</button>
                </div>
            </div>
        </section>

        <!-- Catalog -->
        <section id="catalog">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 2rem;">Haircut Lookbook</h2>
            <div class="filters">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="classic">Classic</button>
                <button class="filter-btn" data-filter="fade">Fade</button>
                <button class="filter-btn" data-filter="modern">Modern</button>
            </div>
            <div class="grid catalog-grid">
                <div class="look-card" data-category="classic" style="background: linear-gradient(135deg, #333, #666)"></div>
                <div class="look-card" data-category="fade" style="background: linear-gradient(45deg, #111, #444, #111)"></div>
                <div class="look-card" data-category="modern" style="background: radial-gradient(circle, #555, #222)"></div>
                <div class="look-card" data-category="classic" style="background: conic-gradient(#444, #777, #444)"></div>
                <div class="look-card" data-category="fade" style="background: linear-gradient(90deg, #222, #555, #222)"></div>
                <div class="look-card" data-category="modern" style="background: radial-gradient(ellipse, #666, #000)"></div>
            </div>
        </section>

        <!-- AI Assistant -->
        <section id="ai">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 3rem;">AI Assistant</h2>
            <p style="text-align: center; max-width: 800px; margin: 0 auto 3rem;">Toggle the chat below for personalized recommendations.</p>
            <div id="ai-panel" class="ai-panel">
                <div class="ai-header">Elite AI 🤖</div>
                <div class="ai-messages" id="ai-messages">
                    <div class="message bot">Hello! How can I help with your grooming today?</div>
                </div>
                <div class="ai-input">
                    <input type="text" id="ai-input" placeholder="Ask about haircuts, barbers...">
                    <button class="btn" onclick="sendMessage()">Send</button>
                </div>
            </div>
        </section>

        <!-- Customer Area -->
        <section id="customer">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 3rem;">Customer Area</h2>
            <div class="grid stats-grid">
                <div class="card stat-card">
                    <div class="stat-number">12</div>
                    <p>Bookings</p>
                </div>
                <div class="card stat-card">
                    <div class="stat-number">8</div>
                    <p>Favorites</p>
                </div>
                <div class="card stat-card">
                    <div class="stat-number">3</div>
                    <p>Notifications</p>
                </div>
            </div>
            <div style="max-width: 800px; margin: 3rem auto;">
                <h3>Booking History</h3>
                <div class="list">
                    <div class="list-item">
                        <span>Haircut - John - Oct 10, 10AM</span>
                        <div>
                            <button class="btn btn-secondary" style="padding:0.5rem 1rem; font-size:0.8rem;">Reschedule</button>
                            <button class="btn" style="padding:0.5rem 1rem; font-size:0.8rem; background:red;">Cancel</button>
                        </div>
                    </div>
                    <!-- More items -->
                    <div class="list-item">
                        <span>Beard - Alex - Oct 15, 2PM</span>
                        <div><button class="btn btn-secondary" style="padding:0.5rem 1rem; font-size:0.8rem;">Reschedule</button></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Admin Panel -->
        <section id="admin">
            <h2 style="text-align: center; font-size: 3rem; margin-bottom: 3rem;">Admin Dashboard</h2>
            <div class="grid stats-grid">
                <div class="card stat-card">
                    <div class="stat-number">24</div>
                    <p>Today's Appointments</p>
                </div>
                <div class="card stat-card">
                    <div class="stat-number">150</div>
                    <p>Total Customers</p>
                </div>
                <div class="card stat-card">
                    <div class="stat-number">4</div>
                    <p>Barbers</p>
                </div>
                <div class="card stat-card">
                    <div class="stat-number">98%</div>
                    <p>Satisfaction</p>
                </div>
            </div>
            <div style="max-width: 800px; margin: 3rem auto;">
                <h3>Daily Agenda</h3>
                <div class="list">
                    <div class="list-item">
                        <span>John: Haircut - 10AM</span>
                        <span><button class="btn" style="padding:0.5rem; font-size:0.8rem;">Confirm</button></span>
                    </div>
                    <!-- More -->
                </div>
            </div>
        </section>
    </main>

    <button class="ai-toggle" onclick="toggleAI()">🤖</button>

    <script>
        // Navigation
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const section = link.dataset.section;
                showSection(section);
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                link.classList.add('active');
            });
        });

        function showSection(id) {
            document.querySelectorAll('section').forEach(s => {
                s.classList.remove('active');
            });
            document.getElementById(id).classList.add('active');
        }

        // Services
        document.querySelectorAll('.service-card').forEach(card => {
            card.addEventListener('click', () => {
                selectedService = card.dataset.service;
                showSection('booking');
                document.getElementById('step1').querySelectorAll('.service-select').forEach(btn => btn.classList.remove('available'));
                // Simulate select
            });
        });

        // Barbers in services? No, separate.

        // Booking logic
        let currentStep = 1;
        let selectedService = '';
        let selectedBarber = '';
        let selectedDate = '';
        let selectedTime = '';

        function nextStep() {
            if (currentStep === 1 && !selectedService) return alert('Select a service');
            if (currentStep === 2 && !selectedBarber) return alert('Select a barber');
            if (currentStep === 3 && !selectedDate) return alert('Select a date');
            if (currentStep === 4 && !selectedTime) return alert('Select a time');

            document.querySelectorAll('.booking-step').forEach((step, index) => {
                step.classList.toggle('active', index + 1 === currentStep + 1);
            });

            document.querySelectorAll('.progress-step')[currentStep - 1].classList.remove('active');
            currentStep++;
            document.querySelectorAll('.progress-step')[currentStep - 1].classList.add('active');

            document.getElementById('prev-btn').style.display = currentStep > 1 ? 'inline-block' : 'none';
            document.getElementById('next-btn').style.display = currentStep < 5 ? 'inline-block' : 'none';

            if (currentStep === 5) {
                document.getElementById('confirm-details').innerHTML = `
                    Service: ${selectedService}<br>
                    Barber: ${selectedBarber}<br>
                    Date: ${selectedDate}<br>
                    Time: ${selectedTime}
                `;
            }
        }

        function prevStep() {
            document.querySelectorAll('.booking-step').forEach((step, index) => {
                step.classList.toggle('active', index + 1 === currentStep - 1);
            });

            document.querySelectorAll('.progress-step')[currentStep - 1].classList.remove('active');
            currentStep--;
            document.querySelectorAll('.progress-step')[currentStep - 1].classList.add('active');

            document.getElementById('next-btn').style.display = currentStep < 5 ? 'inline-block' : 'none';
        }

        function resetBooking() {
            currentStep = 1;
            selectedService = selectedBarber = selectedDate = selectedTime = '';
            document.querySelectorAll('.booking-step')[0].classList.add('active');
            document.querySelectorAll('.progress-step').forEach((s, i) => s.classList.toggle('active', i === 0));
            document.getElementById('prev-btn').style.display = 'none';
            document.getElementById('next-btn').style.display = 'inline-block';
        }

        // Service select in booking
        document.querySelectorAll('.service-select').forEach(btn => {
            btn.addEventListener('click', () => {
                selectedService = btn.dataset.service;
                btn.classList.add('available');
            });
        });

        document.querySelectorAll('.barber-select').forEach(btn => {
            btn.addEventListener('click', () => {
                selectedBarber = btn.textContent;
                btn.classList.add('available');
            });
        });

        document.querySelectorAll('.date-btn.available, .time-btn.available').forEach(btn => {
            btn.addEventListener('click', () => {
                if (btn.classList.contains('date-btn')) {
                    selectedDate = btn.textContent;
                } else {
                    selectedTime = btn.textContent;
                }
                document.querySelectorAll('.date-btn.available, .time-btn.available').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
            });
        });

        // Catalog filters
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const filter = btn.dataset.filter;
                document.querySelectorAll('.look-card').forEach(card => {
                    card.style.display = filter === 'all' || card.dataset.category === filter ? 'block' : 'none';
                });
            });
        });

        // AI Chat
        let aiPanelVisible = false;
        function toggleAI() {
            aiPanelVisible = !aiPanelVisible;
            document.getElementById('ai-panel').style.display = aiPanelVisible ? 'flex' : 'none';
        }

        function sendMessage() {
            const input = document.getElementById('ai-input');
            const msg = input.value.trim();
            if (!msg) return;

            const messages = document.getElementById('ai-messages');
            messages.innerHTML += `<div class="message user">${msg}</div>`;
            input.value = '';
            messages.scrollTop = messages.scrollHeight;

            setTimeout(() => {
                let response = 'Great choice! Let me help you book that.';
                if (msg.toLowerCase().includes('haircut')) response = 'I recommend a classic fade for a modern look. Shall I suggest a barber?';
                if (msg.toLowerCase().includes('barber')) response = 'John Doe is our fade expert, available at 10AM.';
                if (msg.toLowerCase().includes('time')) response = 'Best times are mornings for less wait.';
                messages.innerHTML += `<div class="message bot">${response}</div>`;
                messages.scrollTop = messages.scrollHeight;
            }, 1000);
        }

        document.getElementById('ai-input').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Barber cards click to booking
        document.querySelectorAll('.barber-card').forEach(card => {
            card.addEventListener('click', () => {
                selectedBarber = card.querySelector('h3').textContent;
                showSection('booking');
            });
        });

        // Initial
        showSection('hero');
    </script>
</body>
</html>